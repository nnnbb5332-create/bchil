<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <Button
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back"
            android:backgroundTint="@color/gray"
            android:textColor="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="إنشاء حساب جديد"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_color"
            android:layout_marginTop="32dp"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="أنشئ حساباً لمراقبة أطفالك"
            android:textSize="14sp"
            android:textColor="@color/gray"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal" />

        <!-- الاسم -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الاسم"
            android:textSize="14sp"
            android:textColor="@color/text_color"
            android:layout_marginTop="32dp" />

        <EditText
            android:id="@+id/nameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="أدخل اسمك"
            android:inputType="textPersonName"
            android:layout_marginTop="8dp"
            android:padding="16dp"
            android:background="@drawable/edit_text_background"
            android:textColor="@color/text_color"
            android:textColorHint="@color/hint_color" />

        <!-- البريد الإلكتروني -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="البريد الإلكتروني"
            android:textSize="14sp"
            android:textColor="@color/text_color"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/emailInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="example@email.com"
            android:inputType="textEmailAddress"
            android:layout_marginTop="8dp"
            android:padding="16dp"
            android:background="@drawable/edit_text_background"
            android:textColor="@color/text_color"
            android:textColorHint="@color/hint_color" />

        <!-- كلمة المرور -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="كلمة المرور"
            android:textSize="14sp"
            android:textColor="@color/text_color"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="6 أحرف على الأقل"
            android:inputType="textPassword"
            android:layout_marginTop="8dp"
            android:padding="16dp"
            android:background="@drawable/edit_text_background"
            android:textColor="@color/text_color"
            android:textColorHint="@color/hint_color" />

        <!-- تأكيد كلمة المرور -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تأكيد كلمة المرور"
            android:textSize="14sp"
            android:textColor="@color/text_color"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/confirmPasswordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="أعد إدخال كلمة المرور"
            android:inputType="textPassword"
            android:layout_marginTop="8dp"
            android:padding="16dp"
            android:background="@drawable/edit_text_background"
            android:textColor="@color/text_color"
            android:textColorHint="@color/hint_color" />

        <!-- زر التسجيل -->
        <Button
            android:id="@+id/registerButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="إنشاء الحساب"
            android:layout_marginTop="32dp"
            android:padding="16dp"
            android:backgroundTint="@color/blue"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp" />

        <!-- رابط تسجيل الدخول -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:layout_gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="لديك حساب بالفعل؟ "
                android:textSize="14sp"
                android:textColor="@color/gray" />

            <TextView
                android:id="@+id/loginLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تسجيل الدخول"
                android:textSize="14sp"
                android:textColor="@color/blue"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
